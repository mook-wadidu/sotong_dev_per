# 소통(Sotong) 환경변수 템플릿 — Vercel/배포 시 이 변수들을 설정한다.
# 실제 .env.local / .env.hosted 는 .gitignore 됨(절대 커밋 금지). 여기엔 placeholder 만.

# ── 데이터 드라이버 ──────────────────────────────
# memory(제로 셋업) | supabase
DB_DRIVER=supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_OR_PUBLISHABLE_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_OR_SECRET_KEY

# ── AI (Google Gemini) ──────────────────────────
# 비우면 mock. 키 있으면 자동 gemini.
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
GEMINI_MODEL=gemini-2.5-flash

# ── 보안 (운영 필수 교체) ────────────────────────
SOTONG_ADMIN_TOKEN=change-me-strong-random-admin-key   # 플랫폼 어드민 접근 키
SOTONG_ENTRY_SECRET=change-me-strong-random-secret     # QR 입장 토큰 HMAC 서명

# ── 웹푸시 (VAPID) — `npx web-push generate-vapid-keys` 로 생성 ──
NEXT_PUBLIC_VAPID_PUBLIC_KEY=YOUR_VAPID_PUBLIC_KEY
VAPID_PRIVATE_KEY=YOUR_VAPID_PRIVATE_KEY
VAPID_SUBJECT=mailto:you@example.com

# ── 데모 ─────────────────────────────────────────
DEMO_SALON_SLUG=salon-demo
